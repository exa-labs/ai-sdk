{
  "name": "@exalabs/ai-sdk",
  "version": "2.1.0",
  "description": "Exa web search tool for Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "exa",
    "search",
    "ai-sdk",
    "vercel",
    "web-search",
    "ai",
    "tools"
  ],
  "author": "Exa",
  "license": "MIT",
  "homepage": "https://exa.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exa-labs/ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/exa-labs/ai-sdk/issues"
  },
  "peerDependencies": {
    "ai": "^6.0.193"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
